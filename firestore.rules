rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funcion helper para verificar autenticacion
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Funcion helper para obtener datos del usuario
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Funcion helper para verificar rol
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    // Funcion helper para verificar institucion
    function belongsToInstitution(institutionId) {
      return isAuthenticated() && getUserData().institutionId == institutionId;
    }

    // Datos de institucion
    function getInstitutionData(institutionId) {
      return get(/databases/$(database)/documents/institutions/$(institutionId)).data;
    }

    // Estado de institucion activa (compat: usa status o isActive)
    function isInstitutionActive(institutionId) {
      let inst = getInstitutionData(institutionId);
      return inst != null && (inst.status == 'active' || inst.isActive == true);
    }
    
    // Funcion helper para verificar si es admin de la institucion
    function isInstitutionAdmin(institutionId) {
      let userData = getUserData();
      return (userData.role == 'admin_sst' || userData.role == 'adminsst') &&
        userData.institutionId == institutionId;
    }
    
    // Super admin del sistema
    function isSuperAdmin() {
      return hasRole('admin');
    }
    
    // Admin de institucion
    function isAdminSst() {
      return isAuthenticated() &&
        (getUserData().role == 'admin_sst' || getUserData().role == 'adminsst');
    }

    // Coleccion de instituciones
    match /institutions/{institutionId} {
      // Lectura: usuarios autenticados de la misma institucion o super admin
      allow read: if isAuthenticated() && (
        belongsToInstitution(institutionId) || 
        isSuperAdmin()
      );
      
      // Crear: cualquier usuario autenticado (para registro inicial)
      allow create: if isAuthenticated();
      
      // Actualizar: solo admin de la institucion o super admin
      allow update: if isSuperAdmin() || (
        isInstitutionAdmin(institutionId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'inviteCode',
          'updatedAt'
        ])
      ) || (
        isInstitutionAdmin(institutionId) &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.isActive == resource.data.isActive &&
        request.resource.data.rejectionReason == resource.data.rejectionReason &&
        request.resource.data.suspensionReason == resource.data.suspensionReason &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'nit',
          'department',
          'city',
          'address',
          'type',
          'institutionPhone',
          'rectorCellPhone',
          'email',
          'documentsUrls',
          'inviteCode',
          'updatedAt'
        ])
      );
      
      // Eliminar: solo super admin
      allow delete: if isSuperAdmin();
    }

    // Coleccion de usuarios
    match /users/{userId} {
      // Lectura: el propio usuario, admin de su institucion, o super admin
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        (isAdminSst() && resource.data.institutionId == getUserData().institutionId)
      );
      
      // Crear: usuario autenticado creando su propio perfil
      allow create: if isAuthenticated() && request.auth.uid == userId && (
        request.resource.data.role in ['user', 'employee'] ||
        (
          request.resource.data.role == 'admin_sst' &&
          request.resource.data.institutionId is string &&
          exists(/databases/$(database)/documents/institutions/$(request.resource.data.institutionId)) &&
          get(/databases/$(database)/documents/institutions/$(request.resource.data.institutionId)).data.email == request.resource.data.email
        )
      );
      
      // Actualizar: el propio usuario o admins
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role &&
          (
            request.resource.data.institutionId == resource.data.institutionId ||
            (
              resource.data.institutionId == null &&
              request.resource.data.institutionId is string &&
              exists(/databases/$(database)/documents/institutions/$(request.resource.data.institutionId)) &&
              isInstitutionActive(request.resource.data.institutionId)
            )
          ) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'displayName',
            'photoUrl',
            'jobTitle',
            'campus',
            'phone',
            'notificationsEnabled',
            'notificationSetupCompleted',
            'notificationSetupVersion',
            'fcmTokens',
            'updatedAt',
            'email',
            'institutionId'
          ])
        ) ||
        (
          // Promocion controlada: user/employee -> admin_sst al registrar institucion
          request.auth.uid == userId &&
          resource.data.role in ['user', 'employee'] &&
          request.resource.data.role in ['admin_sst', 'adminsst'] &&
          resource.data.institutionId == null &&
          request.resource.data.institutionId is string &&
          exists(/databases/$(database)/documents/institutions/$(request.resource.data.institutionId)) &&
          get(/databases/$(database)/documents/institutions/$(request.resource.data.institutionId)).data.email == request.resource.data.email &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'email',
            'displayName',
            'photoUrl',
            'role',
            'institutionId',
            'jobTitle',
            'campus',
            'phone',
            'notificationsEnabled',
            'fcmTokens',
            'createdAt',
            'updatedAt'
          ])
        )
      );
      
      // Eliminar: solo super admin
      allow delete: if isSuperAdmin();
    }

    // Coleccion de eventos - filtrado por institucion
    match /eventos/{eventId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.institutionId == getUserData().institutionId ||
        resource.data.reportadoPor_uid == request.auth.uid
      );
      
      // Crear solo si la institucion del usuario esta activa
      allow create: if isAuthenticated() &&
        isInstitutionActive(getUserData().institutionId) &&
        request.resource.data.reportadoPor_uid == request.auth.uid;
      
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (isInstitutionAdmin(resource.data.institutionId) && isInstitutionActive(resource.data.institutionId)) ||
        resource.data.reportadoPor_uid == request.auth.uid
      );
      
      allow delete: if isSuperAdmin();
    }

    // Contadores del sistema (ej. consecutivo de reportes)
    match /system/{docId} {
      allow read: if isAuthenticated() && docId == 'counters';

      allow create, update: if isAuthenticated() &&
        docId == 'counters' &&
        isInstitutionActive(getUserData().institutionId);

      allow delete: if false;
    }

    // Coleccion de reportes SG-SST (flujo nuevo estructurado)
    match /reports/{reportId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.createdBy == request.auth.uid ||
        resource.data.institutionId == getUserData().institutionId
      );

      allow create: if isAuthenticated() &&
        request.resource.data.createdBy == request.auth.uid &&
        isInstitutionActive(getUserData().institutionId);

      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (isInstitutionAdmin(resource.data.institutionId) && isInstitutionActive(resource.data.institutionId)) ||
        (hasRole('coordinador') && resource.data.institutionId == getUserData().institutionId) ||
        (
          resource.data.createdBy == request.auth.uid &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.institutionId == resource.data.institutionId &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.eventType == resource.data.eventType &&
          request.resource.data.reportType == resource.data.reportType &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'attachments',
            'attachmentsPending',
            'pendingAttachments',
            'updatedAt',
            'statusHistory',
          ])
        )
      );

      allow delete: if isSuperAdmin();
    }

    // Modulo de capacitaciones por institucion
    match /institutions/{institutionId}/trainings/{trainingId} {
      // admin_sst/super: ven todo en su institucion. user: solo publicadas.
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && getUserData().institutionId == institutionId) ||
        (getUserData().institutionId == institutionId && resource.data.status == 'published')
      );

      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && getUserData().institutionId == institutionId && isInstitutionActive(institutionId))
      );

      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && getUserData().institutionId == institutionId && isInstitutionActive(institutionId))
      );

      allow delete: if isSuperAdmin();

      match /responses/{userId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() ||
          (isAdminSst() && getUserData().institutionId == institutionId) ||
          request.auth.uid == userId
        );

        allow create, update: if isAuthenticated() &&
          request.auth.uid == userId &&
          getUserData().institutionId == institutionId &&
          exists(/databases/$(database)/documents/institutions/$(institutionId)/trainings/$(trainingId)) &&
          get(/databases/$(database)/documents/institutions/$(institutionId)/trainings/$(trainingId)).data.status == 'published';

        allow delete: if isSuperAdmin();
      }

      match /attendance/{userId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() ||
          (isAdminSst() && getUserData().institutionId == institutionId) ||
          request.auth.uid == userId
        );

        allow create, update: if isAuthenticated() && (
          isSuperAdmin() ||
          (isAdminSst() && getUserData().institutionId == institutionId && isInstitutionActive(institutionId))
        );

        allow delete: if isSuperAdmin();
      }

      match /progress/{userId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() ||
          (isAdminSst() && getUserData().institutionId == institutionId) ||
          request.auth.uid == userId
        );

        allow create, update: if isAuthenticated() &&
          request.auth.uid == userId &&
          getUserData().institutionId == institutionId &&
          exists(/databases/$(database)/documents/institutions/$(institutionId)/trainings/$(trainingId)) &&
          get(/databases/$(database)/documents/institutions/$(institutionId)/trainings/$(trainingId)).data.status == 'published';

        allow delete: if isSuperAdmin();
      }
    }

    // Modulo de documentos SST por institucion
    match /institutions/{institutionId}/documents/{documentId} {
      // admin_sst/super: ven todo. user/employee: solo publicados.
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && getUserData().institutionId == institutionId) ||
        (getUserData().institutionId == institutionId && resource.data.isPublished == true)
      );

      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && getUserData().institutionId == institutionId && isInstitutionActive(institutionId))
      );

      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && getUserData().institutionId == institutionId && isInstitutionActive(institutionId))
      );

      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && getUserData().institutionId == institutionId && isInstitutionActive(institutionId))
      );

      match /reads/{userId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() ||
          (isAdminSst() && getUserData().institutionId == institutionId) ||
          request.auth.uid == userId
        );

        allow create, update: if isAuthenticated() &&
          request.auth.uid == userId &&
          getUserData().institutionId == institutionId &&
          exists(/databases/$(database)/documents/institutions/$(institutionId)/documents/$(documentId)) &&
          get(/databases/$(database)/documents/institutions/$(institutionId)/documents/$(documentId)).data.isPublished == true;

        allow delete: if isAuthenticated() && (
          isSuperAdmin() ||
          (isAdminSst() && getUserData().institutionId == institutionId)
        );
      }
    }

    // Modulo de inspecciones por institucion
    match /institutions/{institutionId}/inspections/{inspectionId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && getUserData().institutionId == institutionId) ||
        (
          getUserData().institutionId == institutionId &&
          resource.data.assignedToUid == request.auth.uid
        )
      );

      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        (
          isAdminSst() &&
          getUserData().institutionId == institutionId &&
          isInstitutionActive(institutionId)
        )
      );

      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (
          isAdminSst() &&
          getUserData().institutionId == institutionId &&
          isInstitutionActive(institutionId)
        ) ||
        (
          getUserData().institutionId == institutionId &&
          request.auth.uid == resource.data.assignedToUid &&
          resource.data.status != 'cancelled' &&
          resource.data.status != 'completed' &&
          resource.data.status != 'completed_with_findings' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'updatedAt',
            'completedAt',
            'completion',
            'result',
            'statusHistory'
          ]) &&
          request.resource.data.status in [
            'in_progress',
            'completed',
            'completed_with_findings'
          ]
        )
      );

      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (
          isAdminSst() &&
          getUserData().institutionId == institutionId &&
          isInstitutionActive(institutionId)
        )
      );
    }

    // Documentos globales SST (gestion exclusiva del super admin)
    match /global_documents/{documentId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.isPublished == true
      );

      allow create, update, delete: if isSuperAdmin();

      match /reads/{userId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() ||
          request.auth.uid == userId
        );

        allow create, update: if isAuthenticated() &&
          request.auth.uid == userId &&
          exists(/databases/$(database)/documents/global_documents/$(documentId)) &&
          get(/databases/$(database)/documents/global_documents/$(documentId)).data.isPublished == true;

        allow delete: if isSuperAdmin();
      }
    }

    // Coleccion de capacitaciones - filtrado por institucion
    match /trainings/{trainingId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.institutionId == getUserData().institutionId ||
        resource.data.published == true
      );
      
      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && request.resource.data.institutionId == getUserData().institutionId && isInstitutionActive(getUserData().institutionId))
      );
      
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (isInstitutionAdmin(resource.data.institutionId) && isInstitutionActive(resource.data.institutionId))
      );
      
      allow delete: if isSuperAdmin() || (isInstitutionAdmin(resource.data.institutionId) && isInstitutionActive(resource.data.institutionId));
    }

    // Coleccion de asignaciones
    match /assignments/{assignmentId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        isAdminSst() ||
        resource.data.target == 'all' ||
        resource.data.target == request.auth.uid
      );
      
      allow create: if isAuthenticated() && (
        isSuperAdmin() || (isAdminSst() && isInstitutionActive(getUserData().institutionId))
      );
      
      allow update: if isAuthenticated() && (
        isSuperAdmin() || (isAdminSst() && isInstitutionActive(getUserData().institutionId))
      );
      
      allow delete: if isSuperAdmin() || (isAdminSst() && isInstitutionActive(getUserData().institutionId));
    }

    // Coleccion de intentos de capacitacion
    match /trainingAttempts/{attemptId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        isAdminSst() ||
        resource.data.userId == request.auth.uid
      );
      
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      
      allow update, delete: if isSuperAdmin();
    }

    // Coleccion de certificados
    match /certificates/{certId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        isAdminSst() ||
        resource.data.userId == request.auth.uid
      );
      
      allow create: if isAuthenticated() && isInstitutionActive(getUserData().institutionId);
      allow update, delete: if isSuperAdmin();
    }

    // Coleccion de planes de accion
    match /planesDeAccion/{planId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        isAdminSst() ||
        resource.data.responsibleUid == request.auth.uid
      );
      
      allow create: if isAuthenticated() && (
        isSuperAdmin() || (isAdminSst() && isInstitutionActive(getUserData().institutionId))
      );
      
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && isInstitutionActive(getUserData().institutionId)) ||
        (
          resource.data.responsibleUid == request.auth.uid &&
          resource.data.status != 'cerrado' &&
          resource.data.status != 'verificado' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'estado',
            'updatedAt',
            'executionNote',
            'executionEvidence',
            'executionAttachments',
            'executionUpdatedAt',
            'executionUpdatedBy',
            'progressHistory',
            'executedAt'
          ]) &&
          resource.data.status in ['pendiente', 'en_curso'] &&
          (
            (
              resource.data.status == 'pendiente' &&
              request.resource.data.status in ['en_curso', 'ejecutado']
            ) ||
            (
              resource.data.status == 'en_curso' &&
              request.resource.data.status in ['en_curso', 'ejecutado']
            )
          ) &&
          request.resource.data.estado == request.resource.data.status &&
          request.resource.data.executionUpdatedBy == request.auth.uid
        )
      );
      
      allow delete: if isSuperAdmin();
    }

    // Coleccion de invitaciones - lista blanca para registro de empleados
    match /invitations/{invitationId} {
      // Lectura: cualquier usuario autenticado puede buscar su propia invitacion por email
      allow read: if isAuthenticated();
      
      // Crear: solo admins de institucion activa o super admin
      allow create: if isAuthenticated() && (
        isSuperAdmin() || 
        (isAdminSst() && isInstitutionActive(getUserData().institutionId))
      );
      
      // Actualizar: admin de la institucion, super admin, o el usuario aceptando su propia invitacion
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && resource.data.institutionId == getUserData().institutionId) ||
        // Permitir que el usuario actualice status a 'accepted' si es su email
        (request.resource.data.status == 'accepted' && 
         resource.data.email == request.auth.token.email)
      );
      
      // Eliminar: solo admin de la institucion o super admin
      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminSst() && resource.data.institutionId == getUserData().institutionId)
      );
    }
  }
}




