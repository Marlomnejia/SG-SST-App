rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if signedIn() && (userId == request.auth.uid || isAdmin());
      allow create: if signedIn() &&
        ((userId == request.auth.uid && request.resource.data.role == 'user') ||
         isAdmin());
      allow update: if signedIn() &&
        (isAdmin() ||
         (userId == request.auth.uid &&
          request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }

    match /eventos/{eventId} {
      allow create: if signedIn() &&
        request.resource.data.reportadoPor_uid == request.auth.uid;
      allow read: if signedIn() &&
        (resource.data.reportadoPor_uid == request.auth.uid || isAdmin());
      allow update: if signedIn() &&
        (resource.data.reportadoPor_uid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /planesDeAccion/{planId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /trainings/{trainingId} {
      allow read: if isAdmin() || resource.data.published == true;
      allow create, update, delete: if isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if signedIn() &&
        (resource.data.target == 'all' ||
         resource.data.target == request.auth.uid ||
         isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /trainingAttempts/{attemptId} {
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /certificates/{certificateId} {
      allow create: if signedIn() &&
        (request.resource.data.userId == request.auth.uid || isAdmin());
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
  }
}
